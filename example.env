# =============================================================================
# VIVAC API 환경 변수 설정 가이드
# 이 파일을 복사해 .env 파일을 생성하고, 실제 값을 채워 넣으세요.
# cp example.env .env
# =============================================================================

# ---------------------------------------------------------------------------
# 애플리케이션 환경
# local : 서버 로컬 실행 + DB docker-compose
# dev   : 서버 로컬 실행 + DB AWS RDS (bastion 경유)
# prod  : 서버/DB 모두 AWS
# ---------------------------------------------------------------------------
ENVIRONMENT=local

# ---------------------------------------------------------------------------
# 데이터베이스 접속 정보
# local  → docker-compose DB
# prod   → AWS RDS (VPC 내부 직접 접속, DB_HOST = RDS 프라이빗 엔드포인트)
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vivac
DB_USER=vivac
DB_PASSWORD=your_db_password_here

# ---------------------------------------------------------------------------
# Bastion Host 설정 (ENVIRONMENT=dev 일 때 사용)
# 로컬 머신에서 AWS RDS에 접근할 때 SSH 터널을 사용합니다.
# ---------------------------------------------------------------------------
USE_BASTION=false
BASTION_HOST=
BASTION_PORT=22
BASTION_USER=ec2-user
BASTION_SSH_KEY_PATH=~/.ssh/your-bastion-key.pem
BASTION_LOCAL_PORT=5433

# USE_BASTION=true 일 때 터널의 목적지(RDS 프라이빗 엔드포인트)
RDS_HOST=your-db.xxxxxxxx.ap-northeast-2.rds.amazonaws.com
RDS_PORT=5432

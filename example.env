# =============================================================================
# VIVAC API 환경 변수 설정 가이드
# 이 파일을 복사해 .env 파일을 생성하고, 실제 값을 채워 넣으세요.
# cp example.env .env
# =============================================================================

# ---------------------------------------------------------------------------
# 애플리케이션 환경
# local : 서버 로컬 실행 + DB docker-compose
# dev   : 서버/DB 모두 AWS VPC 내부 직접 접속
# prod  : 서버/DB 모두 AWS VPC 내부 직접 접속
# ---------------------------------------------------------------------------
ENVIRONMENT=local

# ---------------------------------------------------------------------------
# 데이터베이스 접속 정보
# local → docker-compose DB (DB_HOST=localhost)
# dev   → RDS 프라이빗 엔드포인트
# prod  → RDS 프라이빗 엔드포인트
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vivac
DB_USER=vivac
DB_PASSWORD=your_db_password_here
